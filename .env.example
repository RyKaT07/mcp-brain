# mcp-brain runtime configuration

# Transport: 'sse' for production (HTTPS via reverse proxy), 'stdio' for local dev.
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8400

# Where the markdown knowledge files live.
MCP_KNOWLEDGE_DIR=/data/knowledge

# Bearer token config (multi-token, per-scope permissions). See config/auth.yaml.example.
MCP_AUTH_CONFIG=/data/auth.yaml

# Public URL of this server, used as the OAuth resource identifier in
# RFC 9728 metadata. Set this to your real https:// URL in production
# so MCP clients that auto-discover the protected resource land at the
# right place. Falls back to http://localhost:${MCP_PORT}/ if unset.
# MCP_PUBLIC_URL=https://mcp.yourdomain.com/
