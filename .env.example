# mcp-brain runtime configuration

# Transport: 'http' for production Streamable HTTP (via reverse proxy),
# 'stdio' for local development. 'sse' is deprecated by the MCP spec
# and silently treated as 'http' for backwards compatibility.
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8400

# Host interface that docker-compose binds port 8400 to. Only affects
# the host side of the published port — MCP_HOST above controls what
# the server inside the container listens on (0.0.0.0 = all container
# interfaces, do not change).
#
#   127.0.0.1  — default. Safe. Use when your reverse proxy (Caddy,
#                Traefik, nginx) runs on the SAME host/LXC as mcp-brain
#                and forwards to 127.0.0.1:8400. Nothing outside this
#                box can reach mcp-brain directly.
#
#   0.0.0.0    — required when your reverse proxy lives on a DIFFERENT
#                host/LXC and reaches mcp-brain over the LAN IP of this
#                machine (cross-LXC Caddy, Caddy on the Proxmox host,
#                etc.). You MUST restrict access at the firewall level
#                — mcp-brain's bearer auth alone is not meant to be
#                exposed to the open internet.
#
# Leave unset to get the safe default (127.0.0.1).
# MCP_PORT_BIND=127.0.0.1

# Where the markdown knowledge files live.
MCP_KNOWLEDGE_DIR=/data/knowledge

# Yaml bearer tokens (multi-token, per-scope permissions) — for Claude
# Code CLI which pastes the bearer directly into ~/.claude.json. See
# config/auth.yaml.example for the format.
MCP_AUTH_CONFIG=/data/auth.yaml

# Public URL of this server, used as:
#   - the OAuth 2.0 issuer URL (where the authorization server lives)
#   - the base for the RFC 9728 Protected Resource Metadata URL
# Set this to your real https:// URL in production so MCP clients that
# auto-discover via WWW-Authenticate + metadata land at the right place.
# Trailing slash is required. Falls back to http://localhost:${MCP_PORT}/
# for local testing.
# MCP_PUBLIC_URL=https://mcp.yourdomain.com/

# ---- OAuth 2.1 authorization server ----
# These are required in HTTP mode if you want claude.ai Custom Connectors
# (web / iOS / Android / desktop chat) to talk to this server — they only
# support OAuth 2.0, not raw bearer headers. For Claude Code CLI which
# uses a static bearer, these are still loaded but never touched.

# Where to persist OAuth-issued clients + access/refresh tokens.
# This file is created + managed by the server; do not edit by hand.
MCP_OAUTH_STORE=/data/oauth-state.json

# Admin secret that gates the consent page (/oauth/consent). Every time
# a new claude.ai device adds the Custom Connector, the browser is
# redirected to a consent form on this server and the user has to
# enter this secret to approve the issue of a new token. Generate via:
#
#     openssl rand -hex 32
#
# Store in your password manager (1Password, Bitwarden) and in this
# .env file on the LXC. Rotation = change here + restart the container.
# If unset, OAuth flow fails at the consent step but the server still
# starts and yaml bearer tokens (laptop CLI) keep working.
MCP_OAUTH_ADMIN_SECRET=

# ---- Todoist integration (optional) ----
# API token from Todoist Settings → Integrations → Developer.
# Works on the free tier (5 projects, unlimited sections, 300 tasks/project).
# If unset, Todoist tools are not registered and the server starts normally
# without task management capabilities.
# TODOIST_API_KEY=

# ---- Nextcloud integration (optional) ----
# Read-only file access via WebDAV. Recommended setup: create a
# dedicated Nextcloud user (e.g. mcp-reader) and share specific
# folders read-only to that account. mcp-brain sees only what you
# share — no code change needed to add/remove access.
#
# Use LAN IP when mcp-brain and Nextcloud are on the same network
# (faster, no hairpin NAT). Use public domain when remote.
# NEXTCLOUD_URL=http://10.0.0.42
# NEXTCLOUD_USER=mcp-reader
# NEXTCLOUD_PASSWORD=

# ---- Trello integration (optional) ----
# Kanban board access. Get API key and token at:
#   https://trello.com/power-ups/admin
# Free tier works. If unset, Trello tools are not registered.
# TRELLO_API_KEY=
# TRELLO_API_TOKEN=

# ---- Google Calendar integration (optional) ----
# OAuth 2.0 with offline refresh token. Setup:
#   1. console.cloud.google.com → New Project → Enable Calendar API
#   2. Credentials → OAuth 2.0 Client ID → Desktop app
#   3. Run: python scripts/google-auth.py <client_id> <client_secret>
#   4. Follow the prompts → paste the refresh token below
#
# The refresh token never expires unless revoked. mcp-brain auto-refreshes
# the short-lived access token (~1h) in memory at runtime.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
