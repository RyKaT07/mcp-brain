{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "mcp-brain",
  "owner": {
    "name": "RyKaT07"
  },
  "plugins": [
    {
      "name": "mcp-brain",
      "source": "./",
      "description": "Persistent AI memory you own and control — self-hosted MCP server for knowledge, briefings, Todoist, Google Calendar, Nextcloud, and Trello. Compatible with Claude Code, claude.ai, Cursor, Windsurf, and any MCP client.",
      "version": "1.0.0",
      "author": {
        "name": "RyKaT07"
      },
      "homepage": "https://brainvlt.com",
      "repository": "https://github.com/RyKaT07/mcp-brain-panel",
      "license": "PolyForm-NC-1.0.0",
      "keywords": [
        "memory",
        "knowledge-base",
        "mcp-server",
        "self-hosted",
        "ai-memory",
        "persistent-memory",
        "productivity",
        "todoist",
        "google-calendar",
        "nextcloud",
        "trello"
      ],
      "category": "productivity",
      "mcpServers": {
        "brain": {
          "type": "http",
          "url": "${BRAIN_URL}/mcp",
          "headers": {
            "Authorization": "Bearer ${BRAIN_TOKEN}"
          }
        }
      }
    }
  ]
}
