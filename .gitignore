# Knowledge data — every subdirectory is personal (work, school, life,
# homelab, people, health, finance, _meta, inbox, and any future scopes).
# Only the meta.yaml.example template is checked in.
knowledge/*/
knowledge/meta.yaml

# Keep directory structure
!knowledge/*/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Config with secrets
.env
config.yaml
config/auth.yaml
data/

# Personal / maintainer-only context — never committed.
# The project-level CLAUDE.md contains references to the maintainer's
# workflow and other private notes; the public-facing equivalent is
# README.md + docs/.
CLAUDE.md

# Lock files from knowledge writes
*.lock

# OS
.DS_Store
