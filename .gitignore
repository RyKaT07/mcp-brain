# Knowledge data — every subdirectory is personal (work, school, life,
# homelab, people, health, finance, _meta, inbox, and any future scopes).
# Only the meta.yaml.example template is checked in.
knowledge/*/
knowledge/meta.yaml

# Keep directory structure
!knowledge/*/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Config with secrets
.env
config.yaml
config/auth.yaml
data/

# OAuth state — issued access/refresh tokens, registered clients.
# Redundant because `data/` is already ignored, but listed explicitly
# so it's clear this file exists and must never be committed. Edit
# by hand only to manually revoke a claude.ai device.
data/oauth-state.json

# Personal / maintainer-only context — never committed.
# The project-level CLAUDE.md contains references to the maintainer's
# workflow and other private notes; the public-facing equivalent is
# README.md + docs/.
# Agent config files (case-insensitive)
[Cc][Ll][Aa][Uu][Dd][Ee].[Mm][Dd]
[Aa][Gg][Ee][Nn][Tt]*.[Mm][Dd]

# Lock files from knowledge writes
*.lock

# OS
.DS_Store
